# ============================================================
# Trading Platform — Web App  (Next.js 15 + Bun)
#
# Build context : monorepo root  (run from TradingApp/)
# Build command :
#   docker build -f apps/web/Dockerfile \
#     --build-arg NEXT_PUBLIC_SERVER_URL=https://api.yourdomain.com \
#     -t trading-web .
#
# NOTE: NEXT_PUBLIC_* vars are baked into the JS bundle at build time.
# You MUST pass NEXT_PUBLIC_SERVER_URL as a --build-arg, not at runtime.
# ============================================================

FROM oven/bun:1.2.18-alpine AS base

# ── Stage 1: Install dependencies ───────────────────────────
FROM base AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Copy workspace manifests — bunfig.toml sets linker=isolated so
# each workspace gets its own node_modules.
COPY package.json bun.lock bunfig.toml ./
COPY apps/web/package.json ./apps/web/package.json

RUN bun install --frozen-lockfile

# ── Stage 2: Build ──────────────────────────────────────────
FROM base AS builder
WORKDIR /app

COPY --from=deps /app/node_modules          ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules

COPY apps/web/ ./apps/web/
COPY package.json bunfig.toml ./

WORKDIR /app/apps/web

# NEXT_PUBLIC_SERVER_URL points the browser at the backend API.
# It is inlined into every JS chunk at build time — cannot be
# changed after the image is built without rebuilding.
ARG NEXT_PUBLIC_SERVER_URL=http://localhost:3004
ENV NEXT_PUBLIC_SERVER_URL=$NEXT_PUBLIC_SERVER_URL

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
# Increase heap for large Next.js builds
ENV NODE_OPTIONS=--max_old_space_size=4096

# next.config.ts sets output:'standalone' → produces .next/standalone/
# with a self-contained server.js and a trimmed node_modules.
RUN bun run build

# ── Stage 3: Production runner ──────────────────────────────
FROM base AS runner
WORKDIR /app

# ── Environment variables ─────────────────────────────────────
# Build-time arg also available at runtime (e.g. for SSR env reads):
ARG NEXT_PUBLIC_SERVER_URL=http://localhost:3004
ENV NEXT_PUBLIC_SERVER_URL=$NEXT_PUBLIC_SERVER_URL

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Server port & hostname
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

RUN addgroup -S nodejs && adduser -S -G nodejs nextjs

# ── Standalone bundle ─────────────────────────────────────────
# .next/standalone/ → server.js entry + minimal node_modules.
# Static assets are NOT inside standalone/ and must be placed
# at the exact paths shown below.
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./

# JS chunks, CSS — server.js expects these at .next/static/
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

# Public directory (favicons, robots.txt, open-graph images, etc.)
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

# Prepare cache directory for Next.js ISR / image optimisation
RUN mkdir -p ./apps/web/.next/cache \
  && chown -R nextjs:nodejs ./apps/web/.next

USER nextjs

EXPOSE 3000

# apps/web/server.js is generated by Next.js standalone output
CMD ["bun", "apps/web/server.js"]
